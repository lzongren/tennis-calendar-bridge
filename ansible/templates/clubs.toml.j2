# Generated by Ansible. Do not edit directly on the server.
[app]
timezone = {{ tennis_timezone | to_json }}
database_path = "data/tennis.db"
sync_interval_minutes = {{ tennis_sync_interval_minutes }}
lookahead_days = {{ tennis_lookahead_days }}
calendar_name = {{ tennis_calendar_name | to_json }}

{% for club in tennis_clubs %}
[[clubs]]
id = {{ club.id | to_json }}
name = {{ club.name | to_json }}
provider = {{ club.provider | to_json }}
base_url = {{ club.base_url | to_json }}
{% if club.login_url is defined and club.login_url %}
login_url = {{ club.login_url | to_json }}
{% endif %}
username_env = {{ club.username_env | to_json }}
password_env = {{ club.password_env | to_json }}
enabled = {{ 'true' if club.enabled | default(true) else 'false' }}
timezone = {{ club.timezone | default(tennis_timezone) | to_json }}
{% if club.options is defined and club.options %}

[clubs.options]
{% for key, value in club.options.items() %}
{{ key }} = {{ value | to_json }}
{% endfor %}
{% endif %}

{% endfor %}
