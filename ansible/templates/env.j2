{% macro env_quote(value) -%}
'{{ value | default('', true) | string | replace("'", "\\'") }}'
{%- endmacro %}
# Generated by Ansible. Do not edit directly on the server.
TENNIS_ADMIN_TOKEN={{ env_quote(vault_tennis_admin_token) }}
TENNIS_CALENDAR_TOKEN={{ env_quote(vault_tennis_calendar_token) }}
{% if tennis_public_base_url | default('') %}
TENNIS_PUBLIC_BASE_URL={{ env_quote(tennis_public_base_url) }}
{% endif %}
TENNIS_CONFIG=/config/clubs.toml
TENNIS_DATA_DIR=/data
TENNIS_HOST_BIND={{ tennis_host_bind }}
TENNIS_HOST_PORT={{ tennis_port }}
TENNIS_BASE_PATH={{ tennis_base_path | default('') }}
TENNIS_SYNC_INTERVAL_MINUTES={{ tennis_sync_interval_minutes }}
TENNIS_LOOKAHEAD_DAYS={{ tennis_lookahead_days }}
TENNIS_HEADLESS={{ 'true' if tennis_headless else 'false' }}

{% set credential_env = vault_tennis_credentials | default({}) %}
{% for club in tennis_clubs %}
{% set club_var_prefix = 'vault_' ~ (club.id | replace('-', '_')) %}
{% set username_value = credential_env.get(club.username_env, lookup('vars', club_var_prefix ~ '_username', default='')) %}
{% set password_value = credential_env.get(club.password_env, lookup('vars', club_var_prefix ~ '_password', default='')) %}
{{ club.username_env }}={{ env_quote(username_value) }}
{{ club.password_env }}={{ env_quote(password_value) }}
{% endfor %}
