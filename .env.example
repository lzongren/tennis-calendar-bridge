# Required for POST /api/sync and other admin endpoints.
TENNIS_ADMIN_TOKEN=replace-with-a-long-random-admin-token

# Required for /calendar/<token>/tennis.ics.
TENNIS_CALENDAR_TOKEN=replace-with-a-long-random-calendar-token

# Optional. Used in dashboard and generated URLs.
TENNIS_PUBLIC_BASE_URL=https://tennis.example.com

# Optional runtime settings.
TENNIS_CONFIG=config/clubs.toml
TENNIS_DATA_DIR=data
TENNIS_HOST_BIND=127.0.0.1
TENNIS_HOST_PORT=8080
# Set this when the app is mounted below an origin, for example /tennis.
TENNIS_BASE_PATH=
TENNIS_SYNC_INTERVAL_MINUTES=60
TENNIS_LOOKAHEAD_DAYS=90
TENNIS_HEADLESS=true

# Example Club Automation portal
EXAMPLE_CLUBAUTOMATION_USERNAME=
EXAMPLE_CLUBAUTOMATION_PASSWORD=

# Example AccuSportView portal
EXAMPLE_ACCUSPORTVIEW_USERNAME=
EXAMPLE_ACCUSPORTVIEW_PASSWORD=

# Example CourtReserve portal
EXAMPLE_COURTRESERVE_USERNAME=
EXAMPLE_COURTRESERVE_PASSWORD=
